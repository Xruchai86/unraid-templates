<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>wireguard-manager</Name>
  <Repository>ghcr.io/Xruchai86/wireguard-manager:latest</Repository>
  <Registry>https://ghcr.io/</Registry>
  <Network>bridge</Network>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project/>
  <Overview>WireGuard Client Manager mit OPNsense API-Integration. Verwaltet WireGuard VPN-Clients direkt ueber die OPNsense API. Erstellt Keypairs, pushed Peers zu OPNsense, generiert QR-Codes und Client-Configs (.conf) zum Download. Web-UI auf Port 8080.</Overview>
  <Category>Network:VPN Network:Management Tools:System</Category>
  <WebUI>http://[IP]:[PORT:8080]</WebUI>
  <Icon>https://raw.githubusercontent.com/DEIN-GITHUB-USER/wireguard-manager/main/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <DonateText/>
  <DonateLink/>
  <DonateImg/>

  <!-- Port -->
  <Config Name="WebUI Port" Target="8080" Default="8080" Mode="tcp" Description="Port fuer die Web-Oberflaeche." Type="Port" Display="always" Required="true" Mask="false">8080</Config>

  <!-- Volume -->
  <Config Name="Data / Configs" Target="/data/configs" Default="/mnt/user/appdata/wireguard-manager/data" Mode="rw" Description="Persistenter Speicher fuer Client-Datenbank und .conf-Dateien." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/wireguard-manager/data</Config>

  <!-- OPNsense API -->
  <Config Name="OPNsense Host" Target="OPNSENSE_HOST" Default="" Description="URL deiner OPNsense-Instanz (mit https://), z.B. https://opnsense.example.com." Type="Variable" Display="always" Required="true" Mask="false"></Config>
  <Config Name="OPNsense API Key" Target="OPNSENSE_KEY" Default="" Description="API-Key aus OPNsense (System &gt; Access &gt; Users &gt; API Keys)." Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="OPNsense API Secret" Target="OPNSENSE_SECRET" Default="" Description="API-Secret passend zum API-Key." Type="Variable" Display="always" Required="true" Mask="true"/>

  <!-- WireGuard Server -->
  <Config Name="Server Public Key" Target="WG_SERVER_PUBKEY" Default="" Description="Public Key des WireGuard-Servers auf OPNsense." Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Endpoint (DDNS / IP)" Target="WG_ENDPOINT" Default="" Description="Oeffentliche Adresse fuer VPN-Clients." Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Server Port" Target="WG_SERVER_PORT" Default="51820" Description="WireGuard Listening-Port auf OPNsense." Type="Variable" Display="always" Required="true" Mask="false">51820</Config>
  <Config Name="Server UUID" Target="WG_SERVER_UUID" Default="" Description="UUID der WireGuard Server-Instanz in OPNsense." Type="Variable" Display="always" Required="true" Mask="false"/>

  <!-- Client Defaults -->
  <Config Name="DNS Server" Target="WG_DNS" Default="1.1.1.1" Description="DNS-Server fuer VPN-Clients." Type="Variable" Display="always" Required="true" Mask="false">1.1.1.1</Config>
  <Config Name="Tunnel Subnet" Target="WG_TUNNEL_SUBNET" Default="10.10.10" Description="Erste drei Oktette des Tunnel-Subnetzes. Clients ab .2." Type="Variable" Display="always" Required="true" Mask="false">10.10.10</Config>
  <Config Name="Default Allowed IPs" Target="WG_DEFAULT_ALLOWED_IPS" Default="0.0.0.0/0, ::/0" Description="Standard AllowedIPs. 0.0.0.0/0 = Full-Tunnel." Type="Variable" Display="always" Required="false" Mask="false">0.0.0.0/0, ::/0</Config>
</Container>
