<?xml version="1.0"?>
<Container version="2">
  <Name>SecondChance-Shelf</Name>
  <Repository>ghcr.io/Xruchai86/secondchance-shelf:latest</Repository>
  <Registry>https://ghcr.io/</Registry>
  <Network>host</Network>
  <Privileged>false</Privileged>
  <Support>https://github.com/DEIN-GITHUB-USER/secondchance-shelf</Support>
  <Project>https://github.com/DEIN-GITHUB-USER/secondchance-shelf</Project>
  <Overview>Local-first Netzwerk-Scanner: Geraete-Discovery (nmap/ARP), VLAN-Zuordnung, Topologie, regelbasierter Sicherheits-Report, OPNsense-Empfehlungen + PDF-Umsetzungsplan. Alles bleibt lokal, keine Telemetrie. Host-Netzwerk noetig fuer L2-Discovery.</Overview>
  <Category>Tools: Network:Management Security:</Category>
  <WebUI>http://[IP]:8848</WebUI>
  <Icon>https://raw.githubusercontent.com/DEIN-GITHUB-USER/secondchance-shelf/main/icon.png</Icon>
  <ExtraParams>--cap-add=NET_RAW --cap-add=NET_ADMIN</ExtraParams>
  <Config Name="AppData" Target="/data" Default="/mnt/user/appdata/secondchance-shelf" Mode="rw" Description="SQLite-DB und Scan-Historie (bleibt lokal)" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/secondchance-shelf</Config>
  <Config Name="NETWORK_NAME" Target="NETWORK_NAME" Default="Homelab" Mode="" Description="Anzeigename des Netzwerks" Type="Variable" Display="always" Required="false" Mask="false">Homelab</Config>
  <Config Name="SCAN_SUBNETS" Target="SCAN_SUBNETS" Default="" Mode="" Description="Komma-getrennte Subnetze, z.B. 10.0.0.0/24,10.0.40.0/24 . Leer = automatisch." Type="Variable" Display="always" Required="false" Mask="false"></Config>
  <Config Name="VLAN_MAP" Target="VLAN_MAP" Default="" Mode="" Description='Subnetz-Praefix -> VLAN-Name als JSON, z.B. {"192.168.1":"LAN","192.168.20":"SRV"}. Leer = ohne VLAN-Labels.' Type="Variable" Display="always" Required="false" Mask="false"></Config>
  <Config Name="SCAN_PROFILE" Target="SCAN_PROFILE" Default="standard" Mode="" Description="quick | standard | deep" Type="Variable" Display="always" Required="false" Mask="false">standard</Config>
  <Config Name="DEMO_MODE" Target="DEMO_MODE" Default="0" Mode="" Description="1 = Demo-Daten zum Anschauen, 0 = echter Scan" Type="Variable" Display="always" Required="false" Mask="false">0</Config>
</Container>
